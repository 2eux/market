# KRONOS AI — RULES_MARKET Environment Template
# Copy to .env and fill in your values

# Trading mode: paper | live
TRADING_MODE=paper
LOG_LEVEL=INFO

# Interactive Brokers
IBKR_USERNAME=zeindexai
IBKR_PASSWORD=
IBKR_ACCOUNT=U25739100
IBKR_HOST=localhost
IBKR_PORT=7497

# Database
DATABASE_URL=postgresql://trading_user:your_password@market-db:5432/ai_trading_db

# Market Data
MARKET_DATA_SOURCE=yfinance
# POLYGON_API_KEY=
# TIINGO_API_KEY=

# Capital
STARTING_CAPITAL=200.00
BROKER_PLAN=lite

# Risk
MAX_DAILY_LOSS_PCT=20.0
MAX_POSITION_PCT=10.0
ADX_THRESHOLD=20.0
COST_EDGE_RATIO=3.0
